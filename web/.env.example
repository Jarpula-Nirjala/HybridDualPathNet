# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database (dev uses SQLite if DATABASE_URL is unset)
DATABASE_URL=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# Model weights
MODEL_WEIGHTS_PATH=weights/final_model.pth
MODEL_WEIGHTS_URL=https://drive.google.com/uc?export=download&id=1rDF-vTOgMSIrpE3rV1OXukyhXiVNxxRq

# Optional: S3 / Cloudflare R2 media storage (production)
USE_S3_MEDIA=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto
